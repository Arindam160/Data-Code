        f"Number of models ({len(model_paths)}) and objectives ({len(OBJECTIVE_DIRECTIONS)}) mismatch"
    assert all(d in ["min", "max"] for d in OBJECTIVE_DIRECTIONS), \
        f"Invalid objective direction. Must be 'min' or 'max', got {OBJECTIVE_DIRECTIONS}"
    assert POP_SIZE > 0, "Population size must be positive"
    assert MAX_GEN > 0, "Maximum generations must be positive"
    assert os.path.exists(SAVE_PATH), f"Save path does not exist: {SAVE_PATH}"
    
