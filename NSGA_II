    try:
        checkpoint = {
            'run': run,
            'generation': generation,
            'X': res.X if hasattr(res, 'X') else None,
            'F': res.F if hasattr(res, 'F') else None,
            'algorithm_state': res.algorithm.__dict__ if hasattr(res, 'algorithm') and res.algorithm else None,
            'timestamp': datetime.now().isoformat()
        }
        checkpoint_path = os.path.join(checkpoint_dir, f"checkpoint_run{run}_gen{generation}.pkl")
        with open(checkpoint_path, 'wb') as f:
            pickle.dump(checkpoint, f)
        logger.debug(f"Saved checkpoint: {checkpoint_path}")
    except Exception as e:
        logger.warning(f"Failed to save checkpoint: {e}")
