        # Plus perturbation
        Xs = pert_plus[:, input_indices]
        Xs_scaled = x_scalers[i].transform(Xs)
        y_plus_s = models[i].predict(Xs_scaled).reshape(-1, 1)
        try:
            y_plus = y_scalers[i].inverse_transform(y_plus_s).flatten()
        except Exception:
            y_plus = np.array(y_plus_s).flatten()
        y_plus = np.clip(y_plus, 0, None)
    
        Xs = pert_minus[:, input_indices]
        Xs_scaled = x_scalers[i].transform(Xs)
        y_minus_s = models[i].predict(Xs_scaled).reshape(-1, 1)
        try:
            y_minus = y_scalers[i].inverse_transform(y_minus_s).flatten()
        except Exception:
            y_minus = np.array(y_minus_s).flatten()
        y_minus = np.clip(y_minus, 0, None)
        
        if OBJECTIVE_DIRECTIONS[i] == "max":
            y_plus = -y_plus
            y_minus = -y_minus
        
        impact_val = 0.5 * (abs(np.mean(y_plus) - global_baseline[i]) + 
                           abs(np.mean(y_minus) - global_baseline[i]))
        impacts.append(impact_val)
    
    global_importance_matrix[j] = impacts

global_importance_df = pd.DataFrame(
    global_importance_matrix,
    columns=[f"Obj{i+1}_Impact" for i in range(N_OBJS)],
    index=VAR_NAMES
)
