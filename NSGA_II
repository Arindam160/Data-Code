def sanitize_filename(fname: str) -> str:
    """Make a filename safe by replacing problematic characters."""
    return "".join(c if c.isalnum() or c in " ._-()" else "_" for c in fname)

def load_pickle_file(path: str):
    """Load pickle file with error handling and support for different formats."""
    try:
        if not os.path.isfile(path):
            raise FileNotFoundError(f"File not found: {path}")
        with open(path, "rb") as f:
            data = pickle.load(f)
        
        # Handle different pickle formats
        if isinstance(data, dict):
            if "model" in data:
                logger.debug(f"Loaded model from dictionary: {path}")
                return data["model"]
            elif "scaler" in data:
                logger.debug(f"Loaded scaler from dictionary: {path}")
                return data["scaler"]
        logger.debug(f"Loaded data from {path}")
        return data
    except Exception as e:
        logger.error(f"Error loading {path}: {e}")
        raise

def ensure_lengths_match(models, x_scalers, y_scalers):
