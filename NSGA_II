class MultiObjectiveModelProblem(Problem):
    """
    PyMOO Problem that predicts N_OBJS outputs using provided models/scalers.
    Expects X as shape (n_individuals, n_vars).
    Outputs F shape (n_individuals, N_OBJS) with sign-flipped values for 'max' objectives
    to conform to pymoo's minimization convention.
    """
    def __init__(self, models, x_scalers, y_scalers, objective_directions, n_jobs=1):
        super().__init__(
            n_var=len(VAR_NAMES),
            n_obj=N_OBJS,
            n_constr=0,
            xl=np.array(LOWER_BOUNDS, dtype=float),
            xu=np.array(UPPER_BOUNDS, dtype=float),
            elementwise_evaluation=False
        )
        self.models = models
        self.x_scalers = x_scalers
        self.y_scalers = y_scalers
        self.objective_directions = objective_directions
        self.n_jobs = n_jobs
        
    def _evaluate_single_objective(self, X, obj_idx):
        """Evaluate a single objective for all individuals."""
        X_for_model = X[:, input_indices]
        X_scaled = self.x_scalers[obj_idx].transform(X_for_model)
        y_scaled_pred = self.models[obj_idx].predict(X_scaled)
        y_scaled_pred = np.array(y_scaled_pred).reshape(-1, 1)
        try:
            y_pred = self.y_scalers[obj_idx].inverse_transform(y_scaled_pred).flatten()
        except Exception:
            y_pred = y_scaled_pred.flatten()
        y_pred = np.clip(y_pred, 0, None)
        if self.objective_directions[obj_idx] == "max":
            y_pred = -y_pred
            
        return y_pred
    
    def _evaluate(self, X, out, *args, **kwargs):
        """
        Vectorized batch evaluation.
        X: (n_individuals, n_var)
        """
        if self.n_jobs > 1:
            # Parallel evaluation
            results = Parallel(n_jobs=self.n_jobs)(
                delayed(self._evaluate_single_objective)(X, i) 
                for i in range(N_OBJS)
            )
            preds_all = list(results)
        else:
            preds_all = []
            for i in range(N_OBJS):
                preds_all.append(self._evaluate_single_objective(X, i))
        out["F"] = np.column_stack(preds_all)

def calculate_hypervolume(F, ref_point_factor=1.1):
    """Calculate hypervolume for a set of points."""
    if not HV_AVAILABLE or len(F) == 0:
        return None
    
    try:
        # Calculate reference point
        ref_point = np.max(F, axis=0) * ref_point_factor + 1e-6
        hv = get_performance_indicator("hv", ref_point=ref_point)
        return hv(F)
    except Exception as e:
        logger.warning(f"Hypervolume calculation failed: {e}")
        return None

def calculate_spread(F):
    """Calculate spread (diversity) metric for a Pareto front."""
    if len(F) < 2:
        return 0.0
    try:
        return float(np.mean(np.std(F, axis=0)))
    except Exception as e:
        logger.warning(f"Spread calculation failed: {e}")
        return 0.0

def save_checkpoint(res, run, checkpoint_dir, generation):
