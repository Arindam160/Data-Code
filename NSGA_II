        raise ValueError(f"Models and scaler lists must be same length. Got {len(models)} models, {len(x_scalers)} x_scalers, {len(y_scalers)} y_scalers")
    logger.info(f"Successfully validated {len(models)} model-scaler pairs")
class ModelCache:
    """Cache for loaded models to avoid redundant loading."""
    def __init__(self):
        self._models = {}
        self._x_scalers = {}
        self._y_scalers = {}
    
    def get_model(self, path: str):
        if path not in self._models:
            self._models[path] = load_pickle_file(path)
        return self._models[path]
    
    def get_x_scaler(self, path: str):
        if path not in self._x_scalers:
            self._x_scalers[path] = load_pickle_file(path)
        return self._x_scalers[path]
    
    def get_y_scaler(self, path: str):
        if path not in self._y_scalers:
            self._y_scalers[path] = load_pickle_file(path)
        return self._y_scalers[path]
